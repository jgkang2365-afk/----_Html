# K2B Automation Settings
# K2B는 Windows 파일 선택창을 사용하므로 화면이 있는 대화형 모드가 필요합니다.
K2B_HEADLESS=false
K2B_ID=your_k2b_id
K2B_PW=your_k2b_password

# Email Settings (Naver SMTP)
NAVER_EMAIL_ID=your_id@naver.com
NAVER_EMAIL_PW=your_app_password

# Report Storage Settings
# Windows 예: Z:\data\측정팀\측정보고서 또는 \\Server\data\측정보고서
REPORT_STORAGE_ROOT=Z:\data\측정팀\측정보고서
# 선택: 관리자 실행에서 Z:가 보이지 않으면 같은 위치의 UNC 루트를 지정합니다.
REPORT_STORAGE_UNC_ROOT=\\NAS\share\data\측정팀\측정보고서
BACKUP_STORAGE_ROOT=Z:\data\측정팀\자동화 툴\측정일지_html\backups

# Google Calendar Sync Settings
# 로컬 서버는 프로젝트 루트의 google-credentials.json 파일도 필요합니다.
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com


# Selenium Manager Path (Optional, if automatic detection fails)
# Windows 예: node_modules\selenium-webdriver\bin\windows\selenium-manager.exe
SE_MANAGER_PATH=

# MES Download Automation Settings
MES_EXE=C:\HWS\MEA\hwsmes.exe
MES_PASSWORD=rkdwhdrn
MES_SAVE_PATH=Z:\data\측정팀\자동화 툴\MES 프로그램 DB
WEB_API_URL=http://localhost:3000
WEB_USERNAME=강종구
WEB_PASSWORD=frn2314@

# MES Daemon Settings
# 사내 Windows PC에서 mes_daemon.py를 실행할 때 사용합니다.
MES_DAEMON_POLL_SECONDS=5
MES_DAEMON_IDLE_RESET_SECONDS=10
MES_DAEMON_MACRO_TIMEOUT_SECONDS=600
MES_DAEMON_DRY_RUN=false

# Health stepping-stone lookup browser: false shows the browser on the Windows development PC.
NATIONAL_SUPPORT_HEADLESS=false


# New business document Windows Worker
DOCUMENT_WORKER_TOKEN=replace_with_a_long_random_secret
DOCUMENT_WORKER_API_URL=http://localhost:3000
DOCUMENT_OUTPUT_ROOT=Z:\data\측정팀\측정보고서
DOCUMENT_WORKER_REALTIME_ENABLED=true
DOCUMENT_WORKER_RECOVERY_POLL_SECONDS=300

# Naver Map & Geocoding API Settings
# 클라이언트 공개용 (네이버 클라우드 웹 다이나믹 맵)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_map_client_id

# 서버 전용 (네이버 클라우드 Geocoding API)
NAVER_MAP_CLIENT_ID=your_naver_map_client_id
NAVER_MAP_CLIENT_SECRET=your_naver_map_client_secret

